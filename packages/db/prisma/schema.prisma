// Schéma Prisma partagé web ↔ worker.
// Source de vérité fonctionnelle : docs/conception/02-modele-donnees.md
//
// Conventions :
//  - Champs en camelCase côté client TS, colonnes/tables en snake_case (@map / @@map).
//  - Tout attribut Actor porte le suffixe *Actor (sourceActor, createdByActor…),
//    fidèle à la convention `_actor` du modèle.
//  - account_id partout : clé tenant, filtre systématique (invariant produit n°1).
//  - Subject.contactIds est un tableau scalaire (UUID[]), PAS une relation
//    (invariant n°13 : sujets multi-contacts sans table de liaison).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

/// Acteur partagé : qui porte la donnée. UI : Moi / Relvo / Externe.
enum Actor {
  user
  ai
  contact
  system
}

enum AccountRole {
  admin
  ceo
  manager
  operator
  viewer
}

enum ContactStatus {
  auto
  complete
}

enum ChannelType {
  email
  whatsapp
}

enum ChannelConfigStatus {
  pending
  connected
  error
  disabled
}

/// Cycle de vie d'un Subject — exclusif, 3 valeurs (M6bis, 2026-07-20).
/// Un sujet est une FENÊTRE DE TRAVAIL temporaire ouverte sur des conversations :
/// `open` (ouverte, défaut) → `validated` (travail fait) ou `closed` (écarté).
/// Valider comme fermer posent `closedAt` : la fenêtre se fige, et les
/// conversations qu'elle portait redeviennent orphelines.
/// `archived` est SUPPRIMÉ (personne ne l'utilisait) et `ignored` a MIGRÉ sur la
/// Conversation — on n'ignore pas une fenêtre, on ignore une source.
/// « Nouveau » N'EST PAS un statut : c'est un marqueur DÉRIVÉ (lastOpenedAt
/// null = jamais ouvert), au même titre que « Urgent » (priority) ou « À faire »
/// (tâches ouvertes).
enum SubjectStatus {
  open
  validated
  closed
}

/// Les trois façons dont un message se range TOUT SEUL, sans IA. Chaque valeur
/// porte son propre discriminant, matérialisé par `Conversation.key` :
///  - `email_subject`   → `email:<interlocuteur>:<objet normalisé>`
///  - `whatsapp_group`  → `wa-group:<chat_id>`
///  - `whatsapp_direct` → `wa-direct:<numéro>`
/// Le type encode le canal parce que le discriminant lui-même en dépend :
/// WhatsApp n'a pas de ligne d'objet, l'email n'a pas de fil de groupe.
enum ConversationType {
  email_subject
  whatsapp_group
  whatsapp_direct
}

/// `ignored` = Relvo cesse d'analyser, de résumer et de trier cette source (le
/// remède au « groupe WhatsApp bavard »). Les messages continuent d'ARRIVER et
/// d'être stockés — on ne perd rien, ils sortent seulement du champ de travail
/// de l'assistant. Réversible par le seul utilisateur.
enum ConversationStatus {
  active
  ignored
}

/// 2 niveaux d'urgence : `normal` (par défaut) et `urgent` (drapeau rouge rare).
/// La rareté est le signal. La disposition « ignoré » est un STATUT, pas une
/// priorité (cf. SubjectStatus.ignored), distincte de l'axe d'urgence.
enum Priority {
  normal
  urgent
}

/// État d'absorption d'un KnowledgeDocument `kind=file` : Relvo l'a lu (✦ injecté
/// dans les prompts) ou l'a écarté du retrieval.
enum AbsorptionStatus {
  read
  ignored
}

enum MessageDirection {
  incoming
  outgoing
}

enum MessageStatus {
  received
  linked
  sent
  failed
  ignored
}

/// Renseigné uniquement quand subjectId = null (message « Sans sujet »).
enum TriageHint {
  too_short
  ambiguous
  prospection
  unknown_sender
  informative_only
  other
}

/// Nature d'une tâche — non affichée par défaut, usage technique (automatisation/stats).
enum TaskKind {
  decision
  reply
  check
  call
  inform
  follow_up
  other
}

enum TaskStatus {
  open
  done
  deleted
}

enum CompletionMode {
  manual
  message_match
  action_match
}

enum ActionType {
  send_message
  other
}

enum ActionStatus {
  open
  in_progress
  done
  cancelled
  failed
}

enum EventEntityType {
  subject
  message
  task
  action
  attachment
  system
}

enum KnowledgeKind {
  file
  note
}

/// Nature d'un jeton à usage unique envoyé par email (vérification ou reset password).
enum VerificationTokenType {
  email_verification
  password_reset
}

// ─────────────────────────────────────────────────────────────
// 1. Account — tenant racine
// ─────────────────────────────────────────────────────────────

model Account {
  id            String      @id @default(uuid()) @db.Uuid
  email         String      @unique
  // Nullable : un compte créé via Google OAuth n'a pas de mot de passe local.
  passwordHash  String?     @map("password_hash")
  firstName     String      @map("first_name")
  lastName      String      @map("last_name")
  role          AccountRole @default(ceo)
  isActive      Boolean     @default(true) @map("is_active")
  // Vérification email (convention Auth.js : null = non vérifié, sinon date de vérif).
  emailVerified DateTime?   @map("email_verified")
  // Avatar (renseigné via Google OAuth principalement).
  image         String?
  // Identifiant Google (sub) — lie un compte à son identité OAuth Google.
  googleId      String?     @unique @map("google_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  folders              Folder[]
  contacts             Contact[]
  channels             Channel[]
  channelConfigs       ChannelConfig[]
  conversations        Conversation[]
  subjectConversations SubjectConversation[]
  subjects             Subject[]
  messages             Message[]
  attachments          Attachment[]
  tasks                Task[]
  actions              Action[]
  eventLogs            EventLog[]
  knowledgeDocuments   KnowledgeDocument[]

  @@map("accounts")
}

// ─────────────────────────────────────────────────────────────
// 2. Folder — conteneur métier (Sujets + Connaissances)
// ─────────────────────────────────────────────────────────────

model Folder {
  id          String   @id @default(uuid()) @db.Uuid
  accountId   String   @map("account_id") @db.Uuid
  name        String
  slug        String
  description String?
  // Logo du domaine (Mémoire) : clés de palette/jeu d'icônes curés (cf.
  // apps/web/src/lib/folders.ts). Null → repli sur le mapping par slug.
  color       String?
  icon        String?
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  account            Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subjects           Subject[]
  messages           Message[]
  knowledgeDocuments KnowledgeDocument[]
  defaultForContacts Contact[]           @relation("ContactDefaultFolder")

  @@unique([accountId, slug])
  @@index([accountId])
  @@map("folders")
}

// ─────────────────────────────────────────────────────────────
// 3. Contact — personne extérieure (tous canaux confondus)
// ─────────────────────────────────────────────────────────────

model Contact {
  id              String        @id @default(uuid()) @db.Uuid
  accountId       String        @map("account_id") @db.Uuid
  firstName       String?       @map("first_name")
  lastName        String        @map("last_name")
  email           String?
  phone           String?
  company         String?
  jobTitle        String?       @map("job_title")
  defaultFolderId String?       @map("default_folder_id") @db.Uuid
  status          ContactStatus @default(auto)
  sourceActor     Actor         @map("source_actor")
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  account          Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  defaultFolder    Folder?        @relation("ContactDefaultFolder", fields: [defaultFolderId], references: [id], onDelete: SetNull)
  sentMessages     Message[]      @relation("MessageSenderContact")
  receivedMessages Message[]      @relation("MessageRecipientContact")
  conversations    Conversation[]
  eventLogs        EventLog[]

  @@index([accountId])
  @@index([accountId, status])
  @@map("contacts")
}

// ─────────────────────────────────────────────────────────────
// 4. Channel — point d'entrée côté utilisateur (boîte mail, n° WhatsApp)
// ─────────────────────────────────────────────────────────────

model Channel {
  id         String      @id @default(uuid()) @db.Uuid
  accountId  String      @map("account_id") @db.Uuid
  name       String
  type       ChannelType
  identifier String
  folderIds  String[]    @map("folder_ids") @db.Uuid
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  account       Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  config        ChannelConfig?
  conversations Conversation[]
  subjects      Subject[]
  messages      Message[]

  @@index([accountId])
  @@map("channels")
}

// ─────────────────────────────────────────────────────────────
// 5. ChannelConfig — configuration technique (1-1 avec Channel)
// ─────────────────────────────────────────────────────────────

model ChannelConfig {
  id                String              @id @default(uuid()) @db.Uuid
  accountId         String              @map("account_id") @db.Uuid
  channelId         String              @unique @map("channel_id") @db.Uuid
  provider          String
  connectionData    Json?               @map("connection_data")
  // Identifiant du compte chez le fournisseur d'intégration (Unipile
  // `account_id`, ex. `acc_imap_…`). C'est la CLÉ de résolution du tenant dans
  // le webhook, qui arrive NON authentifié : on ne connaît pas encore
  // l'accountId, on le retrouve via ce champ (unique global, comme le fait le
  // cron M4.6 avec un accès Prisma hors tenant).
  externalAccountId String?             @unique @map("external_account_id")
  status            ChannelConfigStatus @default(pending)
  lastSyncAt        DateTime?           @map("last_sync_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("channel_configs")
}

// ─────────────────────────────────────────────────────────────
// 5bis. Conversation — couche de TRANSPORT et d'IDENTITÉ (M6bis)
//
// Le regroupement déterministe des messages, calculé À LA RÉCEPTION, sans IA.
// C'est ce qui fait qu'il n'existe plus de « message orphelin » : tout message
// tombe dans une conversation, toujours, parce que le calcul de `key` ne peut
// pas échouer. Une conversation est DURABLE — elle ne se supprime pas et ne se
// termine jamais ; c'est le Subject qui est temporaire (cf. §6).
//
// Une conversation n'est JAMAIS découpée par thème : il faudrait inférer le
// sujet, donc de l'IA à la réception, ce qui ruinerait le déterminisme et
// rendrait son identité instable. La séparation des sujets se joue au niveau du
// MESSAGE (cf. Message.subjectId).
// ─────────────────────────────────────────────────────────────

model Conversation {
  id                String             @id @default(uuid()) @db.Uuid
  accountId         String             @map("account_id") @db.Uuid
  channelId         String             @map("channel_id") @db.Uuid
  type              ConversationType
  /// Clé canonique — LE discriminant, calculé à la réception (cf. enum
  /// ConversationType). Unique par compte : c'est elle qui fait le find-or-create.
  key               String
  /// Objet de l'email, nom du groupe WhatsApp, ou nom de l'interlocuteur.
  title             String
  /// L'interlocuteur, quand c'est un contact enregistré. TOUJOURS null pour un
  /// groupe : un groupe n'a pas d'interlocuteur unique, il EST l'interlocuteur.
  contactId         String?            @map("contact_id") @db.Uuid
  /// Email ou numéro brut, tant que l'interlocuteur n'est pas un contact.
  interlocutorRaw   String?            @map("interlocutor_raw")
  /// `chat_id` WhatsApp — sert aussi de CIBLE D'ENVOI pour la réponse.
  externalThreadId  String?            @map("external_thread_id")
  /// Objet normalisé (type `email_subject` uniquement) — mémorisé pour l'audit
  /// et le débogage ; la clé fait déjà foi.
  normalizedSubject String?            @map("normalized_subject")
  status            ConversationStatus @default(active)
  /// Pilote le tri de la liste (plus récent en tête).
  lastMessageAt     DateTime?          @map("last_message_at")
  /// Dernier message reçu/envoyé — dénormalisé, et c'est délibéré : le KPI
  /// « Sans sujet » se définit comme « le DERNIER message n'est rattaché à
  /// aucun sujet », ce que Prisma ne sait pas exprimer (pas d'ordre dans un
  /// filtre `some`). L'approximation « au moins un message sans sujet » serait
  /// FAUSSE : les messages antérieurs à l'ancre restent sans sujet par
  /// conception, et le KPI ne retomberait jamais à zéro.
  /// Ne bouge qu'à l'ARRIVÉE d'un message — jamais lors d'un rattachement,
  /// puisque rattacher ne change pas l'identité du dernier message.
  lastMessageId     String?            @unique @map("last_message_id") @db.Uuid
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  account     Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  channel     Channel               @relation(fields: [channelId], references: [id], onDelete: Cascade)
  contact     Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lastMessage Message?              @relation("ConversationLastMessage", fields: [lastMessageId], references: [id], onDelete: SetNull)
  messages    Message[]
  subjects    SubjectConversation[]

  @@unique([accountId, key])
  @@index([accountId])
  @@index([accountId, status, lastMessageAt])
  @@index([accountId, channelId])
  @@map("conversations")
}

// ─────────────────────────────────────────────────────────────
// 5ter. SubjectConversation — « ce sujet ÉCOUTE cette conversation », donc les
// nouveaux messages lui reviennent (règle d'ancrage). L'écoute a DEUX bornes :
// `anchorMessageId` (début) et `closingMessageId` (fin). Cf. invariant n°13bis.
//
//   • email    → écoute PERMANENTE : les deux bornes restent NULL, le sujet EST
//                le fil, il balaie tout l'amont et le futur, un nouvel email le
//                rouvre. On ne pose JAMAIS de borne sur un lien email.
//   • WhatsApp → écoute BORNÉE : ancre à l'ouverture, borne de fin posée quand
//                le sujet est validé/fermé (l'écoute s'arrête là).
//
// ⚠️ Cette table ne porte PAS l'appartenance des messages, qui vit sur
// Message.subjectId. Deux liens, deux rôles distincts — c'est la seule
// redondance assumée du modèle.
// ─────────────────────────────────────────────────────────────

model SubjectConversation {
  id              String   @id @default(uuid()) @db.Uuid
  accountId       String   @map("account_id") @db.Uuid
  subjectId       String   @map("subject_id") @db.Uuid
  conversationId  String   @map("conversation_id") @db.Uuid
  /// DÉBUT de l'écoute. Les messages ANTÉRIEURS restent dans la conversation sans
  /// appartenir au sujet. NULL = pas d'ancre = tout le fil (cas email : le sujet
  /// EST le fil). Sur un fil WhatsApp, un swipe droite sur un message plus ancien
  /// la fait REMONTER jusqu'à lui.
  anchorMessageId String?  @map("anchor_message_id") @db.Uuid
  /// FIN de l'écoute — posée quand le sujet est validé/fermé (WhatsApp). Les
  /// messages POSTÉRIEURS n'appartiennent plus au sujet et retombent orphelins.
  /// NULL = écoute encore ouverte (ou lien email, jamais borné). Sans backfill :
  /// une colonne ajoutée par M6ter, vide sur les liens existants.
  closingMessageId String? @map("closing_message_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  anchorMessage  Message?     @relation("SubjectConversationAnchor", fields: [anchorMessageId], references: [id], onDelete: SetNull)
  closingMessage Message?     @relation("SubjectConversationClosing", fields: [closingMessageId], references: [id], onDelete: SetNull)

  @@unique([subjectId, conversationId])
  @@index([accountId])
  @@index([conversationId])
  @@map("subject_conversations")
}

// ─────────────────────────────────────────────────────────────
// 6. Subject — entité centrale du produit
// ─────────────────────────────────────────────────────────────

model Subject {
  id                    String        @id @default(uuid()) @db.Uuid
  accountId             String        @map("account_id") @db.Uuid
  reference             String
  title                 String
  summary               String?       @db.Text
  /// Descriptif rédigé par l'UTILISATEUR (onglet Informations) — aide l'IA à
  /// rattacher un domaine et à chercher dans les bonnes conversations. Distinct
  /// de `summary`, qui héberge le futur rapport d'activité généré par Relvo.
  description           String?       @db.Text
  folderId              String?       @map("folder_id") @db.Uuid
  contactIds            String[]      @default([]) @map("contact_ids") @db.Uuid
  status                SubjectStatus @default(open)
  /// Date de validation OU de fermeture — SIMPLE DATE (déclassée par M6ter). Elle
  /// ne gouverne plus l'appartenance : ce sont les bornes d'écoute
  /// (SubjectConversation.anchor/closing) qui disent quels messages sont dans le
  /// sujet. Null tant que le sujet est ouvert. Cf. invariant n°13bis.
  closedAt              DateTime?     @map("closed_at")
  priority              Priority      @default(normal)
  // Marqueur « En attente » (cumulable, distinct du statut) — posé par Relvo
  // quand un sujet attend une réponse externe. Cf. invariant produit n°7.
  waitingForReply       Boolean       @default(false) @map("waiting_for_reply")
  sourceChannelId       String?       @map("source_channel_id") @db.Uuid
  openedAt              DateTime      @default(now()) @map("opened_at")
  resolvedAt            DateTime?     @map("resolved_at")
  lastActivityAt        DateTime?     @map("last_activity_at")
  lastOpenedAt          DateTime?     @map("last_opened_at")
  resolutionSuggestedAt DateTime?     @map("resolution_suggested_at")
  createdByActor        Actor         @map("created_by_actor")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  account       Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  folder        Folder?               @relation(fields: [folderId], references: [id], onDelete: SetNull)
  sourceChannel Channel?              @relation(fields: [sourceChannelId], references: [id], onDelete: SetNull)
  conversations SubjectConversation[]
  messages      Message[]
  attachments   Attachment[]
  tasks         Task[]
  actions       Action[]
  eventLogs     EventLog[]

  @@unique([accountId, reference])
  @@index([accountId])
  @@index([accountId, status])
  @@index([accountId, priority])
  @@index([accountId, folderId])
  @@map("subjects")
}

// ─────────────────────────────────────────────────────────────
// 7. Message — événement brut reçu/envoyé
// ─────────────────────────────────────────────────────────────

model Message {
  id                 String           @id @default(uuid()) @db.Uuid
  accountId          String           @map("account_id") @db.Uuid
  /// NON NULLABLE : tout message appartient à une conversation, déterminée à la
  /// réception (cf. Conversation). C'est ce qui fait qu'il n'existe PLUS de
  /// message orphelin — le rangement ne peut pas échouer.
  conversationId     String           @map("conversation_id") @db.Uuid
  /// APPARTENANCE SÉMANTIQUE, décidée message par message. Null = ce message
  /// n'est couvert par aucune fenêtre de sujet. Ce n'est plus « message que
  /// Relvo n'a pas su traiter » : c'est la granularité fine qui permet de
  /// séparer des sujets ENTRELACÉS dans un même fil (Karim parle de la sauce
  /// blanche et de la facture emballages en alternance), ce qu'aucune fenêtre
  /// purement temporelle ne saurait faire.
  subjectId          String?          @map("subject_id") @db.Uuid
  // Domaine assigné au message à la réception (classification Relvo). Donne
  // ensuite son domaine au sujet créé à partir du message. Null = non classé.
  folderId           String?          @map("folder_id") @db.Uuid
  channelId          String           @map("channel_id") @db.Uuid
  senderContactId    String?          @map("sender_contact_id") @db.Uuid
  senderRaw          String?          @map("sender_raw")
  // Nom d'affichage de l'expéditeur tel que fourni par le canal à la réception
  // (nom de profil WhatsApp, display-name email) — quand l'expéditeur n'est pas
  // encore un Contact. Sert de label lisible avant la création du contact (M7).
  senderName         String?          @map("sender_name")
  recipientContactId String?          @map("recipient_contact_id") @db.Uuid
  direction          MessageDirection
  externalId         String?          @map("external_id")
  externalThreadId   String?          @map("external_thread_id")
  // true = message reçu dans une conversation de GROUPE (WhatsApp). Hypothèse
  // métier pré-M7 : 1 groupe = 1 sujet, et on répond toujours au GROUPE entier
  // (composer par défaut « Tous » = un envoi au chat_id), pas à un membre.
  isGroup            Boolean          @default(false) @map("is_group")
  subjectLine        String?          @map("subject_line")
  content            String?          @db.Text
  /// Corps HTML original d'un e-mail (M6ter+). `content` reste le texte brut
  /// (aperçus de liste, recherche, IA) ; `contentHtml` porte la mise en forme
  /// d'origine, rendue dans un iframe ISOLÉ (le CSS d'un e-mail est envahissant,
  /// son JS hostile). Null pour WhatsApp et nos envois (texte simple).
  contentHtml        String?          @db.Text @map("content_html")
  receivedAt         DateTime?        @map("received_at")
  sentAt             DateTime?        @map("sent_at")
  // Lecture d'un message (incoming) : posé quand on ouvre la CONVERSATION (et
  // non plus le sujet — M6bis). C'est là que les messages arrivent, et tout
  // message a une conversation : plus de message condamné à rester non-lu faute
  // de sujet. Null = non-lu → pastille et remontée en tête de liste.
  readAt             DateTime?        @map("read_at")
  status             MessageStatus    @default(received)
  triageHint         TriageHint?      @map("triage_hint")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conversation     Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  subject          Subject?              @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  folder           Folder?               @relation(fields: [folderId], references: [id], onDelete: SetNull)
  channel          Channel               @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderContact    Contact?              @relation("MessageSenderContact", fields: [senderContactId], references: [id], onDelete: SetNull)
  recipientContact Contact?              @relation("MessageRecipientContact", fields: [recipientContactId], references: [id], onDelete: SetNull)
  attachments      Attachment[]
  tasks            Task[]
  actions          Action[]
  eventLogs        EventLog[]
  anchorFor        SubjectConversation[] @relation("SubjectConversationAnchor")
  closingFor       SubjectConversation[] @relation("SubjectConversationClosing")
  lastMessageOf    Conversation?         @relation("ConversationLastMessage")

  // Idempotence des webhooks : un provider rejoue ses livraisons. Un même
  // (canal, id externe) ne peut créer qu'un seul Message. NB : Postgres autorise
  // plusieurs NULL sur une contrainte unique → les messages sans id externe
  // (créés en interne) ne sont pas contraints. La dédup applicative reste en
  // ceinture-bretelles côté route webhook (findFirst par externalId).
  @@unique([channelId, externalId])
  @@index([accountId])
  @@index([accountId, subjectId])
  @@index([accountId, conversationId])
  @@index([accountId, externalId])
  @@index([accountId, externalThreadId])
  @@map("messages")
}

// ─────────────────────────────────────────────────────────────
// 8. Attachment — pièce jointe liée à un message
// ─────────────────────────────────────────────────────────────

model Attachment {
  id           String    @id @default(uuid()) @db.Uuid
  accountId    String    @map("account_id") @db.Uuid
  messageId    String    @map("message_id") @db.Uuid
  subjectId    String?   @map("subject_id") @db.Uuid
  name         String
  mimeType     String?   @map("mime_type")
  /// Clé de l'objet dans le stockage (R2), pas une URL : le bucket est privé et
  /// les URLs pré-signées expirent. Toujours signer via `@relvo/storage`.
  storageKey   String    @map("storage_key")
  fileSize     Int?      @map("file_size")
  aiLabel      String?   @map("ai_label")
  aiSummary    String?   @map("ai_summary") @db.Text
  aiAnalysis   String?   @map("ai_analysis") @db.Text
  aiLabelAt    DateTime? @map("ai_label_at")
  aiSummaryAt  DateTime? @map("ai_summary_at")
  aiAnalysisAt DateTime? @map("ai_analysis_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  message Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([accountId, subjectId])
  @@index([messageId])
  @@map("attachments")
}

// ─────────────────────────────────────────────────────────────
// 9. Task — unité de travail DU sujet (pas de l'utilisateur)
// ─────────────────────────────────────────────────────────────

model Task {
  id               String         @id @default(uuid()) @db.Uuid
  accountId        String         @map("account_id") @db.Uuid
  subjectId        String?        @map("subject_id") @db.Uuid
  messageId        String?        @map("message_id") @db.Uuid
  title            String
  description      String?        @db.Text
  sourceActor      Actor          @map("source_actor")
  kind             TaskKind       @default(other)
  status           TaskStatus     @default(open)
  completionMode   CompletionMode @default(manual) @map("completion_mode")
  startDate        DateTime?      @map("start_date") @db.Date
  startTime        DateTime?      @map("start_time") @db.Time(6)
  endDate          DateTime?      @map("end_date") @db.Date
  endTime          DateTime?      @map("end_time") @db.Time(6)
  completedAt      DateTime?      @map("completed_at")
  completedByActor Actor?         @map("completed_by_actor")
  metadata         Json?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subject   Subject?   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  message   Message?   @relation(fields: [messageId], references: [id], onDelete: SetNull)
  actions   Action[]
  eventLogs EventLog[]

  @@index([accountId])
  @@index([accountId, subjectId])
  @@index([accountId, status])
  @@index([accountId, startDate])
  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────
// 10. Action — exécution concrète (ex : envoyer un message)
// ─────────────────────────────────────────────────────────────

model Action {
  id              String       @id @default(uuid()) @db.Uuid
  accountId       String       @map("account_id") @db.Uuid
  subjectId       String       @map("subject_id") @db.Uuid
  taskId          String?      @map("task_id") @db.Uuid
  messageId       String?      @map("message_id") @db.Uuid
  type            ActionType
  title           String
  payload         Json?
  status          ActionStatus @default(open)
  executedByActor Actor?       @map("executed_by_actor")
  executedAt      DateTime?    @map("executed_at")
  metadata        Json?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  task      Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)
  message   Message?   @relation(fields: [messageId], references: [id], onDelete: SetNull)
  eventLogs EventLog[]

  @@index([accountId])
  @@index([accountId, subjectId])
  @@index([accountId, status])
  @@map("actions")
}

// ─────────────────────────────────────────────────────────────
// 11. EventLog — journal de bord
// ─────────────────────────────────────────────────────────────

model EventLog {
  id          String          @id @default(uuid()) @db.Uuid
  accountId   String          @map("account_id") @db.Uuid
  subjectId   String?         @map("subject_id") @db.Uuid
  messageId   String?         @map("message_id") @db.Uuid
  taskId      String?         @map("task_id") @db.Uuid
  actionId    String?         @map("action_id") @db.Uuid
  entityType  EventEntityType @map("entity_type")
  entityId    String?         @map("entity_id") @db.Uuid
  eventType   String          @map("event_type")
  title       String
  description String?         @db.Text
  actor       Actor
  contactId   String?         @map("contact_id") @db.Uuid
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")

  account Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  action  Action?  @relation(fields: [actionId], references: [id], onDelete: SetNull)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([accountId, subjectId])
  @@index([accountId, createdAt])
  @@map("event_logs")
}

// ─────────────────────────────────────────────────────────────
// 12. KnowledgeDocument — base de connaissances (file | note)
// ─────────────────────────────────────────────────────────────

model KnowledgeDocument {
  id               String           @id @default(uuid()) @db.Uuid
  accountId        String           @map("account_id") @db.Uuid
  folderId         String           @map("folder_id") @db.Uuid
  kind             KnowledgeKind
  name             String
  description      String?          @db.Text
  // kind = file
  mimeType         String?          @map("mime_type")
  /// Clé de l'objet dans le stockage (R2), pas une URL — cf. Attachment.storageKey.
  storageKey       String?          @map("storage_key")
  fileSize         Int?             @map("file_size")
  anthropicFileId  String?          @map("anthropic_file_id")
  // État d'absorption (kind=file) : Relvo a lu (✦) ou écarté le document.
  absorptionStatus AbsorptionStatus @default(read) @map("absorption_status")
  aiLabel          String?          @map("ai_label")
  aiSummary        String?          @map("ai_summary") @db.Text
  // kind = note
  content          String?          @db.Text
  // traçabilité
  createdByActor   Actor            @map("created_by_actor")
  updatedByActor   Actor?           @map("updated_by_actor")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  folder  Folder  @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([accountId, folderId])
  @@map("knowledge_documents")
}

// ─────────────────────────────────────────────────────────────
// 13. VerificationToken — jeton à usage unique (vérif email / reset password)
// ─────────────────────────────────────────────────────────────
//
// Volontairement détaché d'Account (pas de FK) : `identifier` porte l'email
// cible. Un compte peut donc recevoir un jeton avant même d'être pleinement
// configuré, et le jeton survit indépendamment du cycle de vie du compte.

model VerificationToken {
  id         String                @id @default(uuid()) @db.Uuid
  identifier String // email cible
  token      String                @unique
  type       VerificationTokenType
  expires    DateTime
  createdAt  DateTime              @default(now()) @map("created_at")

  @@index([identifier])
  @@map("verification_tokens")
}

/// Outbox de suppression de fichiers (M4.6).
///
/// Alimentée par un TRIGGER PostgreSQL (`enqueue_file_deletion`) posé sur toute
/// table porteuse d'un `storage_key`. C'est le seul mécanisme capable de voir
/// passer les suppressions en CASCADE : Prisma en est structurellement aveugle
/// (les actions référentielles sont exécutées par la base, pas par le client).
///
/// La mise en file est atomique avec la suppression ; le worker draine ensuite
/// hors transaction (jamais d'I/O réseau dans une transaction DB).
///
/// ⚠️ Aucune FK vers l'entité d'origine, et c'est voulu : la ligne source
/// n'existe précisément plus quand on arrive ici.
model PendingFileDeletion {
  id         BigInt   @id @default(autoincrement())
  storageKey String   @map("storage_key")
  enqueuedAt DateTime @default(now()) @map("enqueued_at") @db.Timestamptz
  attempts   Int      @default(0)
  lastError  String?  @map("last_error") @db.Text

  @@index([enqueuedAt])
  @@map("pending_file_deletions")
}
