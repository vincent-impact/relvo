# Worker WhatsApp (Baileys) — déployé sur Railway/Render (always-on).
# Même base PostgreSQL que apps/web (le worker écrit les messages entrants).
DATABASE_URL="postgresql://relvo:relvo@localhost:5432/relvo?schema=public"

# Secret partagé pour authentifier les appels web → worker (endpoint `send`).
WORKER_API_SECRET="change-me"

# Port d'écoute du endpoint `send` / healthcheck.
PORT="8081"

# Chemin de persistance de l'état d'auth Baileys (M6).
WA_AUTH_STATE_PATH="./.wa-auth"

# ── Cloudflare R2 — stockage fichiers (M4) ────────────────────────────────────
# Mêmes valeurs que apps/web : le worker écrit les médias WhatsApp entrants
# (M6.6) dans le même bucket. Détail des variables : apps/web/.env.example.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="relvo-files-prod"
R2_JURISDICTION="eu"
