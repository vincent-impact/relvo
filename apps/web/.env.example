# ── apps/web — variables d'environnement ──────────────────────────────────────
# Copier en .env.local pour le dev, renseigner sur Vercel pour la prod.

# Base de données PostgreSQL (Neon en prod, docker compose en local).
DATABASE_URL="postgresql://relvo:relvo@localhost:5432/relvo?schema=public"

# Auth.js (OBLIGATOIRE). Générer avec : openssl rand -base64 33
AUTH_SECRET=""

# URL publique de l'app. Sert à Auth.js et aux liens des emails transactionnels.
# En prod Vercel, mettre l'URL du déploiement (https://…).
AUTH_URL="http://localhost:3000"

# Google OAuth (optionnel). Sans ces clés, seul le login email/mot de passe est
# proposé. Console : https://console.cloud.google.com/apis/credentials
# Redirect URI à déclarer : {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend — emails de vérification et de réinitialisation (optionnel en dev :
# sans clé, le lien est logué dans la console au lieu d'être envoyé).
RESEND_API_KEY=""
EMAIL_FROM="Relvo <onboarding@resend.dev>"
