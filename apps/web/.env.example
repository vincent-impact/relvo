# ── apps/web — variables d'environnement ──────────────────────────────────────
# Copier en .env.local pour le dev, renseigner sur Vercel pour la prod.

# Base de données PostgreSQL (Neon en prod, docker compose en local).
DATABASE_URL="postgresql://relvo:relvo@localhost:5432/relvo?schema=public"

# Auth.js (OBLIGATOIRE). Générer avec : openssl rand -base64 33
AUTH_SECRET=""

# URL publique de l'app. Sert à Auth.js et aux liens des emails transactionnels.
# En prod Vercel, mettre l'URL du déploiement (https://…).
AUTH_URL="http://localhost:3000"

# Google OAuth (optionnel). Sans ces clés, seul le login email/mot de passe est
# proposé. Console : https://console.cloud.google.com/apis/credentials
# Redirect URI à déclarer : {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend — emails de vérification et de réinitialisation (optionnel en dev :
# sans clé, le lien est logué dans la console au lieu d'être envoyé).
RESEND_API_KEY=""
EMAIL_FROM="Relvo <onboarding@resend.dev>"

# ── Cloudflare R2 — stockage fichiers (M4) ────────────────────────────────────
# Les mêmes valeurs sont à renseigner sur apps/worker (médias WhatsApp).
# Dashboard Cloudflare → Storage & databases → R2.

# Visible dans l'URL du dashboard Cloudflare.
R2_ACCOUNT_ID=""

# R2 → API → Manage API tokens. Token de COMPTE, permission « Object Read &
# Write », scopé au(x) bucket(s) — surtout pas « Admin Read & Write ».
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Nom du bucket.
R2_BUCKET="relvo-files-prod"

# Juridiction du bucket, FIGÉE à sa création. `eu` = résidence des données
# garantie en UE (RGPD) et endpoint <account>.eu.r2.cloudflarestorage.com.
# Ne mettre "none" que si le bucket a été créé sans juridiction — sinon les
# appels échouent en 403/404 sans message explicite.
R2_JURISDICTION="eu"

# Secret du cron Vercel (drainage de l'outbox de suppression de fichiers, M4.6).
# Vercel l'injecte en `Authorization: Bearer <CRON_SECRET>` sur les appels cron.
# Générer avec : openssl rand -base64 32
CRON_SECRET=""
